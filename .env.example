# === JARVIS Voice Agent API Keys ===
# Get your free keys from these URLs:

# --- LLM (Ollama auto-detected if running, otherwise Groq) ---
# Ollama (local, FREE) — install from https://ollama.com then: ollama pull qwen3:8b
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
# Groq (cloud, FREE) — get key from https://console.groq.com/keys
GROQ_API_KEY=YOUR_KEY_HERE

# Deepgram STT (https://console.deepgram.com) — $200 free credits
DEEPGRAM_API_KEY=YOUR_KEY_HERE

# ElevenLabs TTS (https://elevenlabs.io) — 10k chars/month free
ELEVENLABS_API_KEY=YOUR_KEY_HERE
VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Brave Search (https://api.search.brave.com) — 2000 queries/month free
BRAVE_API_KEY=YOUR_KEY_HERE
