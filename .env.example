# ╔══════════════════════════════════════════════════════════════╗
# ║          JARVIS Voice Agent — Environment Variables          ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# LLM Priority: Google Gemini (best) → Ollama (local/free) → Groq (cloud free tier)

# ─── LLM: Google Gemini (Recommended) ───
# Get your key: https://aistudio.google.com/app/apikey
GOOGLE_CREDENTIALS=YOUR_KEY_HERE
GOOGLE_MODEL=gemini-2.5-flash

# ─── LLM: Ollama (Local, FREE) ───
# Install: https://ollama.com → then run: ollama pull qwen3:8b
OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# ─── LLM: Groq (Cloud, FREE tier) ───
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=YOUR_KEY_HERE
GROQ_MODEL=llama-3.1-8b-instant

# ─── STT: Deepgram (Required) ───
# Sign up: https://console.deepgram.com — $200 free credits
DEEPGRAM_API_KEY=YOUR_KEY_HERE

# ─── TTS: Kokoro (Local, no key needed) ───
# Runs locally via pipecat — no API key required

# ─── Web Search: Brave Search (Optional) ───
# Get your key: https://api.search.brave.com — 2000 queries/month free
# Falls back to DuckDuckGo if not set
BRAVE_API_KEY=YOUR_KEY_HERE

# ─── Audio Settings ───
AUDIO_GAIN=15.0

# ─── Gmail Integration ───
# Your display name for email signatures
GMAIL_SENDER_NAME=Your Name
# OAuth setup: see README.md "Gmail Setup" section
# No API key needed — uses credentials.json + token.json (OAuth2)
